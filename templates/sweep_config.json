{
  "axes": {
    "embeddings": ["text-embedding-3-small", "text-embedding-3-large"],
    "chunk_size": [256, 512, 1024],
    "top_k": [3, 5, 8],
    "temperature": [0.0, 0.3, 0.7]
  },
  "command": "python3 eval.py --embeddings {embeddings} --chunk-size {chunk_size} --top-k {top_k} --temperature {temperature}",
  "strategy": "random",
  "max_runs": 20,
  "results_path": "sweep_results.jsonl",
  "seed": 42
}
