{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/update-context.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/snapshot-state.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "ashen-ai-eng-builder|ashen-data-eng-builder|ashen-infra-ops-builder|ashen-generalist-builder",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-tests-on-stop.sh"
          }
        ]
      }
    ]
  }
}
